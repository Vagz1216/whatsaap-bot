# WooCommerce API
WC_BASE_URL=https://stayez.co.ke
WC_CONSUMER_KEY=your_wc_key
WC_CONSUMER_SECRET=your_wc_secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ENABLE_CALLBACKS=true

# Social listener webhooks
ENABLE_WEBHOOK_SERVER=true
WEBHOOK_PORT=3100
META_WEBHOOK_VERIFY_TOKEN=change_me

# Dashboard auth
# Production: use Clerk JWT verification. The dashboard/client must send
# Authorization: Bearer <Clerk session token> to dashboard API requests.
# DASHBOARD_TOKEN is only a local/internal fallback when CLERK_JWKS_URL is not set.
DASHBOARD_REQUIRE_AUTH=true
DASHBOARD_TOKEN=
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_SECRET_KEY=
PLATFORM_OWNER_EMAILS=admin@example.com

# LLM Providers
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Tenant BYOK
# Keep this stable across deploys; changing it prevents decrypting encrypted tenant LLM keys.
SECRET_ENCRYPTION_KEY=
ORGANIZATION_LLM_KEYS_ENABLED=true
ORGANIZATION_LLM_PROVIDER_MODE=platform_first

# Langfuse Observability
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com # Note: Ensure this is https://cloud.langfuse.com for EU or https://us.cloud.langfuse.com for US

# Timezone and Logging
TZ=Africa/Nairobi
LOG_LEVEL=info
