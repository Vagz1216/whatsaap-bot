# StayEZ SaaS / Azure-Coolify environment template
# Copy this file when preparing deployment secrets. Leave optional values blank
# unless that integration is required for the deployment.

# ---------------------------------------------------------------------------
# SaaS database - required for multi-tenant deployment
# ---------------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------------
# HTTP server - required
# ---------------------------------------------------------------------------
ENABLE_WEBHOOK_SERVER=true
WEBHOOK_PORT=3100
# Azure may inject PORT. WEBHOOK_PORT takes precedence when set.
# PORT=

# ---------------------------------------------------------------------------
# Dashboard auth - required for production
# ---------------------------------------------------------------------------
# Production should use Clerk JWT verification. The deployed dashboard/client
# must send Authorization: Bearer <Clerk session token> to API requests.
DASHBOARD_REQUIRE_AUTH=true
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_SECRET_KEY=
PLATFORM_OWNER_EMAILS=

# Local/internal fallback only. Do not use as the primary production auth path.
DASHBOARD_TOKEN=
DASHBOARD_RATE_LIMIT_PER_MINUTE=120

# ---------------------------------------------------------------------------
# Platform LLM providers - at least one provider chain is required.
# Azure OpenAI is the preferred production provider.
# ---------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
# Backward-compatible alias. Prefer AZURE_OPENAI_DEPLOYMENT_NAME for new deploys.
AZURE_OPENAI_DEPLOYMENT=

# Optional fallback providers.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Not currently used by the platform router as global provider keys.
# Cerebras can still be added per tenant from /llm-credentials using BYOK.
# CEREBRAS_API_KEY=
# GOOGLE_API_KEY=
# GROK_API_KEY=

# ---------------------------------------------------------------------------
# Tenant BYOK - required if tenants will store their own LLM keys.
# Keep SECRET_ENCRYPTION_KEY stable across deploys.
# ---------------------------------------------------------------------------
SECRET_ENCRYPTION_KEY=
ORGANIZATION_LLM_KEYS_ENABLED=true
ORGANIZATION_LLM_PROVIDER_MODE=platform_first

# ---------------------------------------------------------------------------
# Social webhook verification - optional, required only for public Meta webhooks.
# Tenant Meta access tokens are normally stored per tenant in Neon.
# ---------------------------------------------------------------------------
META_WEBHOOK_VERIFY_TOKEN=
# Local fallback only when no tenant Meta token is configured.
META_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Single-tenant/local integration fallback only.
# In SaaS mode, tenant integrations are read from tenant_configs in Postgres.
# Leave WC_* and TELEGRAM_* blank in production SaaS unless DATABASE_URL is not set
# and you are intentionally running the old single-tenant bot mode.
# ---------------------------------------------------------------------------
WC_BASE_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLE_CALLBACKS=true

# ---------------------------------------------------------------------------
# Observability - optional.
# Langfuse is disabled automatically when keys or package support are absent.
# ---------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
DATA_DIR=/app/data
TZ=Africa/Nairobi
LOG_LEVEL=info
